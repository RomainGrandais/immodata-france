{
  "version": 2,
  "functions": {
    "api/v1/bien.js":           { "maxDuration": 15 },
    "api/v1/valuation.js":     { "maxDuration": 15 },
    "api/v1/rental-yield.js":  { "maxDuration": 15 },
    "api/v1/market-trends.js": { "maxDuration": 15 },
    "api/mcp.js":              { "maxDuration": 30 },
    "api/health.js":           { "maxDuration": 5  },
    "api/auth/register.js":   { "maxDuration": 10 },
    "api/auth/login.js":      { "maxDuration": 10 },
    "api/auth/me.js":         { "maxDuration": 10 },
    "api/keys/index.js":      { "maxDuration": 10 },
    "api/keys/revoke.js":     { "maxDuration": 10 },
    "api/stripe/checkout.js": { "maxDuration": 15 },
    "api/stripe/webhook.js":  { "maxDuration": 15 },
    "api/stripe/portal.js":   { "maxDuration": 15 }
  },
  "routes": [
    { "src": "/health",                 "dest": "/api/health.js" },
    { "src": "/v1/bien",                "dest": "/api/v1/bien.js" },
    { "src": "/v1/valuation",           "dest": "/api/v1/valuation.js" },
    { "src": "/v1/rental-yield",        "dest": "/api/v1/rental-yield.js" },
    { "src": "/v1/market-trends",       "dest": "/api/v1/market-trends.js" },
    { "src": "/mcp",                    "dest": "/api/mcp.js" },
    { "src": "/api/auth/register",      "dest": "/api/auth/register.js" },
    { "src": "/api/auth/login",         "dest": "/api/auth/login.js" },
    { "src": "/api/auth/me",            "dest": "/api/auth/me.js" },
    { "src": "/api/keys",               "dest": "/api/keys/index.js" },
    { "src": "/api/keys/revoke",        "dest": "/api/keys/revoke.js" },
    { "src": "/api/stripe/checkout",    "dest": "/api/stripe/checkout.js" },
    { "src": "/api/stripe/webhook",     "dest": "/api/stripe/webhook.js" },
    { "src": "/api/stripe/portal",      "dest": "/api/stripe/portal.js" },
    { "src": "/openapi.json",           "dest": "/public/openapi.json" },
    { "src": "/app",                    "dest": "/public/app.html" },
    { "src": "/docs",                   "dest": "/public/index.html" },
    { "src": "/llms.txt",               "dest": "/llms.txt" },
    { "src": "/(.*)",                   "dest": "/api/v1/bien.js" }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "Access-Control-Allow-Origin",  "value": "*" },
        { "key": "Access-Control-Allow-Methods", "value": "GET, POST, DELETE, OPTIONS" },
        { "key": "Access-Control-Allow-Headers", "value": "Content-Type, x-api-key, Authorization" },
        { "key": "X-Content-Type-Options",       "value": "nosniff" },
        { "key": "X-Frame-Options",              "value": "SAMEORIGIN" },
        { "key": "Referrer-Policy",              "value": "no-referrer" },
        { "key": "Strict-Transport-Security",    "value": "max-age=63072000; includeSubDomains; preload" }
      ]
    }
  ]
}
